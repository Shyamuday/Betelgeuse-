{
  "name": "vitalis-clinic-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "npm run dev --prefix apps/api",
    "dev:web": "npm start --prefix apps/web",
    "dev:doctor": "npm start --prefix apps/doctor-web",
    "dev:admin": "npm start --prefix apps/admin-web",
    "dev:api": "npm run dev --prefix apps/api",
    "build": "npm run build --prefix apps/api && npm run build --prefix apps/web",
    "build:web": "npm run build --prefix apps/web",
    "build:doctor": "npm run build --prefix apps/doctor-web",
    "build:admin": "npm run build --prefix apps/admin-web",
    "build:api": "npm run build --prefix apps/api",
    "mobile:patient:sync": "npm run sync --prefix apps/mobile-patient",
    "mobile:doctor:sync": "npm run sync --prefix apps/mobile-doctor",
    "mobile:admin:sync": "npm run sync --prefix apps/mobile-admin",
    "format": "prettier --write \"apps/**/*.{ts,html,scss,css,json}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"apps/**/*.{ts,html,scss,css,json}\" \"docs/**/*.md\"",
    "lint": "npm run lint --prefix apps/api",
    "prisma:generate": "npm run prisma:generate --prefix apps/api",
    "prisma:migrate": "npm run prisma:migrate --prefix apps/api",
    "seed": "npm run seed --prefix apps/api"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
