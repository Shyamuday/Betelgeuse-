generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ConsultationStatus {
  PAYMENT_PENDING
  PAID
  ASSIGNED
  IN_PROGRESS
  PRESCRIPTION_UPLOADED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String?        @unique
  mobile              String?        @unique
  passwordHash        String?
  role                Role
  isActive            Boolean        @default(true)
  doctorProfile       Doctor?
  patientConsults     Consultation[] @relation("PatientConsultations")
  doctorConsults      Consultation[] @relation("DoctorConsultations")
  messages            Message[]
  uploadedPrescriptions Prescription[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Doctor {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialty      String
  registrationNo String?
  isAvailable    Boolean  @default(true)
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Disease {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String
  feeInPaise    Int
  intakeQuestions Json
  isActive      Boolean        @default(true)
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Consultation {
  id              String             @id @default(cuid())
  patientId       String
  diseaseId       String
  assignedDoctorId String?
  status          ConsultationStatus @default(PAYMENT_PENDING)
  intakeAnswers   Json
  patient         User               @relation("PatientConsultations", fields: [patientId], references: [id])
  disease         Disease            @relation(fields: [diseaseId], references: [id])
  assignedDoctor  User?              @relation("DoctorConsultations", fields: [assignedDoctorId], references: [id])
  payment         Payment?
  messages        Message[]
  prescription    Prescription?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  consultationId  String        @unique
  provider        String        @default("razorpay")
  providerOrderId String?
  providerPaymentId String?
  amountInPaise   Int
  status          PaymentStatus @default(CREATED)
  consultation    Consultation  @relation(fields: [consultationId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  consultationId String
  senderId       String
  body           String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
  createdAt      DateTime     @default(now())
}

model Prescription {
  id             String       @id @default(cuid())
  consultationId String       @unique
  uploadedById   String
  notes          String
  fileUrl        String?
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])
  createdAt      DateTime     @default(now())
}
