/// Generic key-value store for clinic-wide settings editable by admin.
/// Keys are stable identifiers (e.g. "doctorListLimit", "whatsappPhone").
model SiteConfig {
  key       String   @id
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@index([key])
}

enum PublicContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model PublicPage {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  subtitle    String?
  summary     String?             @db.Text
  content     Json?
  seo         Json?
  status      PublicContentStatus @default(PUBLISHED)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([sortOrder])
}

model HomeCarouselSlide {
  id               String   @id @default(cuid())
  title            String
  subtitle         String?  @db.Text
  eyebrow          String?
  imageAlt         String?
  imageKey         String?
  externalImageUrl String?
  actionLabel      String?
  actionType       String   @default("BOOK")
  actionUrl        String?
  isPublished      Boolean  @default(true)
  sortOrder        Int      @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}

model HomeAnnouncement {
  id          String   @id @default(cuid())
  text        String   @db.Text
  linkLabel   String?
  linkUrl     String?
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
  @@index([sortOrder])
}
