model NotificationTemplate {
  id         String                  @id @default(cuid())
  code       String                  @unique
  name       String
  title      String
  body       String
  channel    String                  @default("IN_APP")
  isActive   Boolean                 @default(true)
  broadcasts NotificationBroadcast[]
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
}

model NotificationBroadcast {
  id             String                @id @default(cuid())
  templateId     String?
  template       NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  title          String
  body           String
  channel        String
  audience       String
  audienceRole   Role?
  recipientCount Int                   @default(0)
  createdById    String?
  createdBy      User?                 @relation("NotificationBroadcasts", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())

  @@index([createdAt])
}

model InAppNotification {
  id                   String   @id @default(cuid())
  recipientUserId      String?
  recipientStoreStaffId String?
  eventType            String
  title                String
  body                 String
  metadata             Json?
  readAt               DateTime?
  createdAt            DateTime @default(now())

  recipientUser        User?       @relation("UserInAppNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)
  recipientStoreStaff  StoreStaff? @relation("StoreStaffInAppNotifications", fields: [recipientStoreStaffId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, readAt, createdAt])
  @@index([recipientStoreStaffId, readAt, createdAt])
}
