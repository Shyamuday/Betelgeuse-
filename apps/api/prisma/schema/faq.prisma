model FaqEntry {
  id          String   @id @default(cuid())
  question    String
  answer      String   @db.Text
  category    String   @default("General")
  isPublished Boolean  @default(true)
  sortOrder   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, category])
}
