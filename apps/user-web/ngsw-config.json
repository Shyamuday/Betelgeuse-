{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/site.webmanifest",
          "/favicon-192x192.png",
          "/favicon-512x512.png",
          "/apple-touch-icon.png",
          "/hopehublogo.png",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "public-content",
      "urls": ["/diseases/**", "/doctors/**", "/clinics/**", "/blog/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 80,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/**/*__*", "!/**/*__*/**"]
}
